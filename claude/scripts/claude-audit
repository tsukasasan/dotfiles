#!/bin/bash
# claude-audit: Review Claude Code session tool usage
# Scans ~/.claude/projects/ for session data and displays tool calls

set -euo pipefail

# Colors
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
RESET='\033[0m'

PROJECTS_DIR="$HOME/.claude/projects"
NUM_SESSIONS=5
FILTER=""

usage() {
  echo "Usage: claude-audit [OPTIONS]"
  echo ""
  echo "Options:"
  echo "  -n NUM        Number of recent sessions to show (default: 5)"
  echo "  --commands    Show only Bash commands"
  echo "  --edits       Show only file edits (Edit/Write)"
  echo "  -h, --help    Show this help"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -n)
      NUM_SESSIONS="$2"
      shift 2
      ;;
    --commands)
      FILTER="commands"
      shift
      ;;
    --edits)
      FILTER="edits"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      usage
      exit 1
      ;;
  esac
done

if [[ ! -d "$PROJECTS_DIR" ]]; then
  echo "No Claude Code projects found at $PROJECTS_DIR"
  exit 1
fi

# Dangerous command patterns for color coding
is_dangerous() {
  local cmd="$1"
  if [[ "$cmd" =~ rm[[:space:]]+-[a-zA-Z]*r[a-zA-Z]*f ]] ||
     [[ "$cmd" =~ git[[:space:]]+push[[:space:]]+--force ]] ||
     [[ "$cmd" =~ git[[:space:]]+reset[[:space:]]+--hard ]] ||
     [[ "$cmd" =~ git[[:space:]]+clean[[:space:]]+-f ]] ||
     [[ "$cmd" =~ (curl|wget).*\|.*(bash|sh) ]] ||
     [[ "$cmd" =~ dd[[:space:]].*of=/dev/ ]] ||
     [[ "$cmd" =~ (shutdown|reboot|halt|poweroff) ]] ||
     [[ "$cmd" =~ chmod[[:space:]]+777 ]]; then
    return 0
  fi
  return 1
}

# Find session files, sorted by modification time (newest first)
session_files="$(find "$PROJECTS_DIR" -name '*.jsonl' -type f -printf '%T@ %p\n' 2>/dev/null | \
  sort -rn | head -n "$NUM_SESSIONS" | awk '{print $2}')"

if [[ -z "$session_files" ]]; then
  echo "No session files found"
  exit 0
fi

while IFS= read -r session_file; do
  # Extract project path from directory name
  project_dir="$(basename "$(dirname "$session_file")")"
  session_id="$(basename "$session_file" .jsonl)"
  mod_time="$(date -r "$session_file" '+%Y-%m-%d %H:%M' 2>/dev/null || stat -c '%y' "$session_file" 2>/dev/null | cut -d. -f1)"

  echo -e "${BLUE}=== Session: ${session_id:0:8}... ===${RESET}"
  echo -e "${BLUE}    Project: $project_dir${RESET}"
  echo -e "${BLUE}    Time:    $mod_time${RESET}"
  echo ""

  # Extract tool calls
  if [[ "$FILTER" == "commands" ]]; then
    jq_filter='select(.type == "tool_use" and .tool_name == "Bash") | "  Bash: " + (.tool_input.command // "N/A")'
  elif [[ "$FILTER" == "edits" ]]; then
    jq_filter='select(.type == "tool_use" and (.tool_name == "Edit" or .tool_name == "Write")) | "  " + .tool_name + ": " + (.tool_input.file_path // "N/A")'
  else
    jq_filter='select(.type == "tool_use") | "  " + .tool_name + ": " + (if .tool_name == "Bash" then (.tool_input.command // "N/A") elif .tool_name == "Edit" or .tool_name == "Write" then (.tool_input.file_path // "N/A") elif .tool_name == "Read" then (.tool_input.file_path // "N/A") else "..." end)'
  fi

  # Process each line as a separate JSON object
  while IFS= read -r line; do
    if [[ -z "$line" ]]; then
      continue
    fi

    # Color dangerous commands in red, safe ones in green
    if [[ "$line" =~ ^[[:space:]]*Bash: ]]; then
      cmd="${line#*Bash: }"
      if is_dangerous "$cmd"; then
        echo -e "  ${RED}Bash: $cmd${RESET}"
      else
        echo -e "  ${GREEN}Bash: $cmd${RESET}"
      fi
    else
      echo -e "  ${YELLOW}$line${RESET}"
    fi
  done < <(jq -r "$jq_filter" "$session_file" 2>/dev/null || true)

  echo ""
done <<< "$session_files"
